---
import AdminLayout from '../layouts/AdminLayout.astro';
import FormularioProduto from '../components/FormProduct.astro';
import { pool } from '../lib/db.js';
import fs from 'node:fs/promises';
import path from 'node:path';

//cadastrar produto
let mensagemSistema = "";

if (Astro.request.method === "POST") {
    try {
        const dados = await Astro.request.formData();
        const nome = dados.get("nome");
        const descricao = dados.get("descricao");
        const mensagem_whatsapp = dados.get("mensagem_whatsapp");
        const arquivoFoto = dados.get("foto");

        let nomeFotoFinal = null;
        if (arquivoFoto && typeof arquivoFoto === 'object' && arquivoFoto.name && arquivoFoto.size > 0) {            nomeFotoFinal = `${Date.now()}-${arquivoFoto.name.replace(/\s+/g, '-')}`;
            
            const diretorioUploads = path.join(process.cwd(), 'public', 'uploads');
            await fs.mkdir(diretorioUploads, { recursive: true });
            
            const caminhoArquivo = path.join(diretorioUploads, nomeFotoFinal);
            const buffer = Buffer.from(await arquivoFoto.arrayBuffer());
            await fs.writeFile(caminhoArquivo, buffer);
        }
        await pool.query(
            'INSERT INTO admin_user.produtos (nome, descricao, mensagem_whatsapp, foto) VALUES ($1, $2, $3, $4)',
            [nome, descricao, mensagem_whatsapp, nomeFotoFinal]
        );
        
        mensagemSistema = "Produto cadastrado com sucesso.";
    } catch (erro) {
        console.error(erro);
        mensagemSistema = "Erro ao salvar o produto no banco de dados.";
    }
}
// busca produtos
let produtos = [];
try {
    const consultaProdutos = await pool.query('SELECT * FROM admin_user.produtos ORDER BY criado_em DESC');
    produtos = consultaProdutos.rows;
} catch (erro) {
    console.error("Erro ao buscar produtos:", erro);
}
---

<AdminLayout title="Painel de Controle">
    <div class="min-h-screen bg-gray-50 p-8">
        <div class="max-w-6xl mx-auto">
            <div class="flex justify-between items-center bg-white p-4 rounded-lg shadow-sm border border-gray-100 mb-6">
                <h1 class="text-2xl font-bold text-gray-800">Gestão de Produtos</h1>
                <a href="/" class="text-red-600 font-semibold hover:underline">Sair do Sistema</a>
            </div>
            
            {mensagemSistema && (
                <div class="bg-blue-100 border border-blue-300 text-blue-800 p-4 mb-6 rounded-lg font-medium">
                    {mensagemSistema}
                </div>
            )}

            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                
                <div>
                    <FormularioProduto />
                </div>
                <div>
                    <h2 class="text-xl font-bold mb-4 text-gray-800 mt-6 lg:mt-0">Produtos Cadastrados</h2>
                    
                    <div class="bg-white rounded-lg shadow-md border border-gray-100 overflow-hidden">
                        {produtos.length === 0 ? (
                            <p class="p-6 text-gray-500 text-center">Nenhum produto cadastrado ainda.</p>
                        ) : (
                            <ul class="divide-y divide-gray-100 max-h-96 overflow-y-auto">
                                {produtos.map((produto: any) => (
                                    <li class="p-4 hover:bg-gray-50 flex items-center gap-4 transition-colors">
                                        
                                        <!-- Miniatura da Imagem -->
                                        {produto.foto ? (
                                            <img 
                                                src={`/uploads/${produto.foto}`} 
                                                alt={produto.nome} 
                                                class="w-16 h-16 object-cover rounded-md border border-gray-200"
                                            />
                                        ) : (
                                            <div class="w-16 h-16 bg-gray-100 rounded-md border border-gray-200 flex items-center justify-center text-gray-400 text-xs text-center">
                                                Sem foto
                                            </div>
                                        )}
                                        
                                        <div class="flex-1">
                                            <h3 class="font-bold text-gray-800">{produto.nome}</h3>
                                            <p class="text-sm text-gray-500 line-clamp-1">{produto.descricao}</p>
                                        </div>

                                    </li>
                                ))}
                            </ul>
                        )}
                    </div>
                </div>

            </div>
        </div>
    </div>
</AdminLayout>