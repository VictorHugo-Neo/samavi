---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Painel de Controle">
    <div class="min-h-screen bg-gray-100 p-8">
        <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-sm p-6">
            <h1 class="text-3xl font-bold text-gray-800">Bem-vindo ao Painel Samavi! 🎉</h1>
            <p class="text-gray-600 mt-2">Você fez login com sucesso. Em breve, a gestão de produtos ficará aqui.</p>
            
            <div class="mt-8">
                <a href="/" class="text-red-600 hover:underline font-semibold">Sair (Logout)</a>
            </div>
        </div>
    </div>
</AdminLayout>