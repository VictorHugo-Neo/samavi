---
import { pool } from '../../lib/db.js';

let produtos = [];
try {
    const consultaProdutos = await pool.query('SELECT * FROM admin_user.produtos ORDER BY criado_em DESC');
    produtos = consultaProdutos.rows;
} catch (erro) {
    console.error("Erro ao buscar produtos:", erro);
}
---
<div>
                    <h2 class="text-xl font-bold mb-4 text-gray-800 mt-6 lg:mt-0">Produtos Cadastrados</h2>
                    
                    <div class="bg-white rounded-lg shadow-md border border-gray-100 overflow-hidden">
                        {produtos.length === 0 ? (
                            <p class="p-6 text-gray-500 text-center">Nenhum produto cadastrado ainda.</p>
                        ) : (
                            <ul class="divide-y divide-gray-100 max-h-96 overflow-y-auto">
                                {produtos.map((produto: any) => (
                                    <li class="p-4 hover:bg-gray-50 flex items-center gap-4 transition-colors">
                                        
                                        <!-- Miniatura da Imagem -->
                                        {produto.foto ? (
                                            <img 
                                                src={`/uploads/${produto.foto}`} 
                                                alt={produto.nome} 
                                                class="w-16 h-16 object-cover rounded-md border border-gray-200"
                                            />
                                        ) : (
                                            <div class="w-16 h-16 bg-gray-100 rounded-md border border-gray-200 flex items-center justify-center text-gray-400 text-xs text-center">
                                                Sem foto
                                            </div>
                                        )}
                                        
                                        <div class="flex-1">
                                            <h3 class="font-bold text-gray-800">{produto.nome}</h3>
                                            <p class="text-sm text-gray-500 line-clamp-1">{produto.descricao}</p>
                                        </div>

                                    </li>
                                ))}
                            </ul>
                        )}
                    </div>
                </div>