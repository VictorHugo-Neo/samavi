<form method="POST" enctype="multipart/form-data" class="bg-white p-6 rounded-lg shadow-md border border-gray-100 mt-6">    <h2 class="text-xl font-bold mb-4 text-gray-800">Cadastrar Novo Produto</h2>
    
    <div class="mb-4">
        <label for="nome" class="block text-sm font-bold text-gray-700 mb-2">Nome do Produto</label>
        <input type="text" id="nome" name="nome" required class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:border-red-500" placeholder="Ex: Sofá Retrátil" />
    </div>

    <div class="mb-4">
        <label for="descricao" class="block text-sm font-bold text-gray-700 mb-2">Descrição</label>
        <textarea id="descricao" name="descricao" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:border-red-500" placeholder="Detalhes do produto..."></textarea>
    </div>

    <div class="mb-6">
        <label for="mensagem_whatsapp" class="block text-sm font-bold text-gray-700 mb-2">Mensagem Automática (WhatsApp)</label>
        <input type="text" id="mensagem_whatsapp" name="mensagem_whatsapp" class="w-full border border-gray-300 p-3 rounded-lg outline-none focus:border-red-500" placeholder="Olá, tenho interesse no Sofá Retrátil..." />
    </div>
    <div class="mb-6">
        <label for="foto" class="block text-sm font-bold text-gray-700 mb-2">Foto do Produto</label>
        <input type="file" id="foto" name="foto" accept="image/*" class="w-full border border-gray-300 p-2 rounded-lg outline-none focus:border-red-500" />
    </div>
    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-lg w-full">
        Salvar Produto
    </button>
</form>